# Next.js build workers need to resolve jest-worker (processChild.js); pnpm strict
# layout can cause MODULE_NOT_FOUND. Hoisting fixes resolution.
node-linker=hoisted

# Ensure eslint binaries resolve on Windows when workspace packages run `eslint` / `pnpm exec eslint`
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=@eslint/*
