# ============================================================
# Production deploy (apps/web): set at least NEXT_PUBLIC_* below.
# Optional: RPC_EU_URL, RPC_AU_URL for /api/rpc proxy. Set FAUCET_API_URL for real faucet (no mock).
# Copy to .env.local (local) or set in host (Vercel, etc.).
# ============================================================

# Database Configuration (backend / full-stack only)
POSTGRES_DB=axionax
POSTGRES_USER=axionax
POSTGRES_PASSWORD=change_this_password_in_production

# API Keys (generate your own)
EXPLORER_API_KEY=your_explorer_api_key_here
FAUCET_API_KEY=your_faucet_api_key_here

# RPC Configuration
RPC_NETWORK=mainnet
RPC_CHAIN_ID=86150

# Frontend Environment Variables
NEXT_PUBLIC_APP_VERSION=1.9.0-mainnet
NEXT_PUBLIC_CHAIN_ID=86150
NEXT_PUBLIC_NETWORK_NAME=axionax-mainnet-1
NEXT_PUBLIC_API_URL=https://mainnet.api.axionax.org
NEXT_PUBLIC_INDEXER_API_URL=http://localhost:3001
NEXT_PUBLIC_RPC_URL=https://mainnet.rpc.axionax.org
NEXT_PUBLIC_WS_URL=wss://mainnet.ws.axionax.org
NEXT_PUBLIC_EXPLORER_URL=https://mainnet.explorer.axionax.org
NEXT_PUBLIC_EXPLORER_API_URL=https://mainnet.explorer-api.axionax.org
# Faucet is typically disabled on mainnet.
NEXT_PUBLIC_FAUCET_URL=
NEXT_PUBLIC_FAUCET_API_URL=
# Server-side: leave empty to disable web faucet proxy in production/mainnet.
FAUCET_API_URL=

# Redis Configuration
REDIS_URL=redis://redis:6379

# Node Environment
NODE_ENV=production

# --- Live Metrics (Frontend) ---
# Prefer same-origin reverse proxy under /api to avoid mixed-content on HTTPS.
# If you must override, provide a full base URL to the explorer API (HTTPS only).
# Example: NEXT_PUBLIC_EXPLORER_API=https://api.axionax.org/api
NEXT_PUBLIC_EXPLORER_API=

# Validator RPC reverse-proxy paths (recommended):
# Example: NEXT_PUBLIC_RPC_EU=/rpc/eu
# Example: NEXT_PUBLIC_RPC_AU=/rpc/au
NEXT_PUBLIC_RPC_EU=
NEXT_PUBLIC_RPC_AU=

# Polling interval for live metrics (ms)
NEXT_PUBLIC_REFETCH_MS=5000

# Faucet Configuration (testnet only; keep empty on mainnet)
# FAUCET_PRIVATE_KEY=your_private_key_here

# Optional: directory for site visitor counter JSON (default: apps/web/data). Use on VPS for persistence.
# VISITOR_DATA_DIR=/var/lib/axionax-web
